<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head") %>
</head>

<body>
    <div class="site-wrapper">
        <%- include("partials/header") %>

            <main class="main-content">
                <section class="hero-section">
                    <div class="container hero-grid">
                        <div class="hero-text">
                            <span class="eyebrow">Professional Website Template</span>
                            <h1>Build polished multi-page websites faster.</h1>
                            <p>
                                A clean EJS and Express starter with reusable partials, modern styling,
                                and a footer that stays at the bottom of the page.
                            </p>

                            <div class="hero-actions">
                                <a href="/page2" class="btn btn-primary">Explore Pages</a>
                                <a href="/page3" class="btn btn-secondary">View Layout</a>
                            </div>
                        </div>

                        <div class="hero-card">
                            <div class="stat-card">
                                <h3>Reusable Pages</h3>
                                <p>Use this as a base for portfolios, business sites, dashboards, or class projects.</p>
                            </div>
                            <div class="mini-grid">
                                <div class="mini-box">Modern UI</div>
                                <div class="mini-box">Sticky Footer</div>
                                <div class="mini-box">Shared Partials</div>
                                <div class="mini-box">Easy to Expand</div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="feature-section">
                    <div class="container">
                        <div class="section-heading">
                            <span class="eyebrow">Why this works</span>
                            <h2>Clean, professional, and easy to reuse</h2>
                            <p>
                                Designed with strong spacing, subtle shadows, soft borders, and a
                                modern business-style layout.
                            </p>
                        </div>

                        <div class="cards">
                            <article class="card">
                                <h3>Professional Layout</h3>
                                <p>Balanced spacing, clean typography, and a strong visual hierarchy.</p>
                            </article>

                            <article class="card">
                                <h3>Multi-Page Ready</h3>
                                <p>Keep building on the same header, footer, and design system.</p>
                            </article>

                            <article class="card">
                                <h3>Assignment Friendly</h3>
                                <p>Simple structure that is easy to explain, edit, and submit later.</p>
                            </article>
                        </div>
                    </div>
                </section>
            </main>

            <%- include("partials/footer") %>
    </div>
</body>

</html>