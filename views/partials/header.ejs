<header class="site-header">
    <div class="container nav">
        <a href="/" class="logo">TemplateSite</a>

        <nav class="nav-wrap">
            <ul class="nav-links">
                <li><a class="<%= pageName === 'Home' ? 'active' : '' %>" href="/">Home</a></li>
                <li><a class="<%= pageName === 'Page 2' ? 'active' : '' %>" href="/page2">Page 2</a></li>
                <li><a class="<%= pageName === 'Page 3' ? 'active' : '' %>" href="/page3">Page 3</a></li>
                <li><a class="<%= pageName === 'Page 4' ? 'active' : '' %>" href="/page4">Page 4</a></li>
                <li><a class="<%= pageName === 'Page 5' ? 'active' : '' %>" href="/page5">Page 5</a></li>
            </ul>

            <div class="auth-links">
                <% if (user) { %>
                    <span class="user-badge">Hi, <%= user.name %></span>
                    <a class="auth-btn" href="/logout">Logout</a>
                    <% } else { %>
                        <a class="auth-btn <%= pageName === 'Login' ? 'active-auth' : '' %>" href="/login">Login</a>
                        <a class="auth-btn auth-btn-secondary <%= pageName === 'Sign Up' ? 'active-auth' : '' %>"
                            href="/signup">Sign Up</a>
                        <% } %>
            </div>
        </nav>
    </div>
</header>